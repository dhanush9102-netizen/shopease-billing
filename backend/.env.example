# ================================================================
#  ShopEase Billing — Backend Environment Variables
#  Copy this file to .env for LOCAL development only.
#  On Render: add these in the "Environment" tab — NOT as a file.
#  NEVER commit your real .env to GitHub.
# ================================================================

# Server port (Render sets this automatically — leave as 3000 locally)
PORT=3000

# ── Clever Cloud MySQL ──────────────────────────────────────
# Copy these EXACTLY from:
#   Clever Cloud Console → your app → Add-ons → MySQL → Env variables
#
MYSQL_ADDON_HOST=your-host.services.clever-cloud.com
MYSQL_ADDON_USER=your_cc_username
MYSQL_ADDON_PASSWORD=your_cc_password
MYSQL_ADDON_DB=your_cc_database_name
MYSQL_ADDON_PORT=3306

# ── CORS ────────────────────────────────────────────────────
# Set to * during first deploy, then update to your Vercel URL:
# e.g. https://shopease-billing.vercel.app
FRONTEND_URL=http://localhost:5500
